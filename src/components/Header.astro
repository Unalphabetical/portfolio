---
import ThemeToggle from '@components/ThemeToggle.astro';

const navLinks = [
  { label: 'Home', href: '#hero' },
  { label: 'Skills', href: '#skills' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-50 bg-base-100/80 backdrop-blur-md border-b border-base-300">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16" aria-label="Main navigation">
    <a href="/" class="text-fluid-lg font-bold tracking-tight">
      Puth Vang
    </a>

    <div class="flex items-center gap-6">
      <ul class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="text-sm font-medium text-base-content/70 hover:text-base-content transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <ThemeToggle />

      <button class="md:hidden btn btn-ghost btn-square swap swap-rotate" aria-label="Toggle menu" id="menu-btn">
        <svg class="swap-off size-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
        </svg>
        <svg class="swap-on size-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M6 6l12 12M18 6l-12 12" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </nav>

  <div class="md:hidden hidden" id="mobile-menu">
    <ul class="flex flex-col px-4 pb-4 gap-2">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block px-3 py-2 rounded-btn text-sm font-medium text-base-content/70 hover:text-base-content hover:bg-base-200 transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    menuBtn.classList.toggle('swap-active');
    menu?.classList.toggle('hidden');
  });

  document.querySelectorAll('#mobile-menu a').forEach((link) => {
    link.addEventListener('click', () => {
      menuBtn?.classList.remove('swap-active');
      menu?.classList.add('hidden');
    });
  });
</script>
