---
const navLinks = [
  { label: 'Home', href: '#hero' },
  { label: 'Skills', href: '#skills' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-50 bg-base-100/80 backdrop-blur-md border-b border-base-200">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16" aria-label="Main navigation">
    <a href="/" class="text-fluid-lg font-bold tracking-tight">
      Puth Vang
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="text-sm font-medium text-base-content/70 hover:text-base-content transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <label class="flex md:hidden swap swap-rotate" aria-label="Toggle menu">
      <input type="checkbox" class="theme-controller hidden" />
      <svg class="swap-off fill-current size-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
      </svg>
      <svg class="swap-on fill-current size-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M6 6l12 12M18 6l-12 12" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
      </svg>
    </label>
  </nav>

  <div class="md:hidden hidden peer-checked:block" id="mobile-menu">
    <ul class="flex flex-col px-4 pb-4 gap-2">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block px-3 py-2 rounded-btn text-sm font-medium text-base-content/70 hover:text-base-content hover:bg-base-200 transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector('.swap input');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('change', () => {
    menu?.classList.toggle('hidden', !toggle.checked);
  });

  document.querySelectorAll('#mobile-menu a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle.checked = false;
      menu?.classList.add('hidden');
    });
  });
</script>
