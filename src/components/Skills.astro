---
const groups = [
  {
    title: 'Languages',
    items: ['Java', 'Python', 'JavaScript', 'HTML / CSS', 'SQL'],
  },
  {
    title: 'Frameworks & Libraries',
    items: ['Astro', 'React', 'Tailwind CSS'],
  },
  {
    title: 'Tools & Platforms',
    items: ['Vite', 'Node.js', 'Git', 'MySQL'],
  },
];
---

<section class="py-24 reveal" id="skills" data-reveal-delay="0">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="bg-base-200/50 rounded-box p-6 sm:p-10">
    <h2 class="text-fluid-2xl font-bold mb-2">Skills</h2>
    <p class="text-base-content/60 mb-10">Languages and tools I work with</p>
    <div class="flex flex-wrap gap-12 justify-between reveal-children">
      {groups.map((group) => (
        <div class="flex-1 basis-40">
          <h3 class="text-fluid-base font-semibold text-primary mb-4">{group.title}</h3>
          <ul class="list-disc list-inside marker:text-primary space-y-1.5">
            {group.items.map((name) => (
              <li class="text-base-content/80">{name}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>
