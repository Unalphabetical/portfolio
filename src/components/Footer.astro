---
import { socials } from '@data/socials.js';
const year = new Date().getFullYear();
---

<footer class="border-t border-base-300 mt-auto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      {socials.map((s) => (
        <a
          href={s.url}
          class="text-sm text-base-content/60 hover:text-base-content transition-colors"
          target={s.name === 'Email' ? undefined : '_blank'}
          rel={s.name === 'Email' ? undefined : 'noopener noreferrer'}
        >
          {s.name}
        </a>
      ))}
    </div>
    <p class="text-sm text-base-content/40">&copy; {year} Puth Vang</p>
  </div>
</footer>
