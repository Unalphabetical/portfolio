---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Skills from '@components/Skills.astro';
import Projects from '@components/Projects.astro';
import Contact from '@components/Contact.astro';

const title = 'Puth Vang — Software & Full-Stack Developer';
const description =
  'Puth Vang is a software and full-stack web developer studying Computer Science at California State University, Sacramento.';
---

<BaseLayout title={title} description={description}>
  <Hero />

  <hr class="max-w-6xl mx-auto px-4 sm:px-6 border-t border-base-content/50" />

  <Skills />

  <hr class="max-w-6xl mx-auto px-4 sm:px-6 border-t border-base-content/50" />

  <Projects />

  <hr class="max-w-6xl mx-auto px-4 sm:px-6 border-t border-base-content/50" />

  <Contact />
</BaseLayout>
