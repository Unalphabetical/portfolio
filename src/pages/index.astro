---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Puth Vang — Software & Full-Stack Developer';
const description =
  'Puth Vang is a software and full-stack web developer studying Computer Science at California State University, Sacramento.';
---

<BaseLayout title={title} description={description}>
  <section id="hero" class="min-h-screen flex items-center justify-center text-center">
  </section>

  <section id="skills" class="py-24">
  </section>

  <section id="projects" class="py-24">
  </section>

  <section id="contact" class="py-24">
  </section>
</BaseLayout>
